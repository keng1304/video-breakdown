# video-breakdown 環境變數範本
#
# 複製成 .env 後填值：
#   cp .env.example .env

# ── 必填 ──────────────────────────────────────
# Anthropic API Key（Claude Vision 做每鏡描述 + prompt 生成）
# 取得：https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=

# ── 可選 ──────────────────────────────────────
# 輸出資料夾（預設：專案根目錄下的 output/）
# VIDEO_BREAKDOWN_OUTPUT=

# 處理解析度上限（預設 720）
# MAX_PROCESS_RESOLUTION=720

# Claude 模型（預設 claude-sonnet-4-20250514）
# CLAUDE_MODEL=claude-sonnet-4-20250514
